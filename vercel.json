{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/arcoin run build",
  "outputDirectory": "artifacts/arcoin/dist/public",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
